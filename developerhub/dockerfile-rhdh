# ==================================================
# 1. Build stage
# ==================================================
FROM node:20.18.3 AS builder

WORKDIR /app

ENV npm_config_build_from_source=false \
    npm_config_ignore_optional=true \
    YARN_ENABLE_SCRIPTS=1 \
    NODE_OPTIONS=--max_old_space_size=8192

RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    gcc \
    pkg-config \
    git \
    build-essential \
 && rm -rf /var/lib/apt/lists/*

RUN corepack enable \
 && corepack prepare yarn@4.16.0 --activate

# ----------------------------------
# Root metadata
# ----------------------------------
COPY package.json yarn.lock .yarnrc.yml ./
COPY .yarn .yarn

# ----------------------------------
# Config files
# ----------------------------------
COPY app-config*.yaml ./

# ----------------------------------
# Workspace package.json のみ
# ----------------------------------
COPY packages packages
COPY plugins plugins
COPY dynamic-plugins dynamic-plugins

RUN find packages -type f ! -name package.json -delete || true
RUN find plugins -type f ! -name package.json -delete || true
RUN find dynamic-plugins -type f ! -name package.json -delete || true

RUN yarn config set nodeLinker node-modules

RUN yarn install --immutable

# ----------------------------------
# Full source
# ----------------------------------
COPY . .

RUN yarn build

# ==================================================
# 2. Runtime stage
# ==================================================
FROM registry.redhat.io/rhdh/rhdh-hub-rhel9:1.10.0

WORKDIR /opt/app-root/src

ENV NODE_ENV=production \
    NODE_OPTIONS=--max_old_space_size=4096

USER 0

RUN microdnf install -y \
    jq \
    tar \
    gzip \
 && microdnf clean all

# ----------------------------------
# Backstage bundles
# ----------------------------------
COPY --from=builder /app/dist/skeleton.tar.gz .
COPY --from=builder /app/dist/bundle.tar.gz .

RUN tar xzf skeleton.tar.gz \
 && rm -f skeleton.tar.gz

RUN tar xzf bundle.tar.gz \
 && rm -f bundle.tar.gz

# ----------------------------------
# Dynamic plugins
# ----------------------------------
COPY --from=builder /app/dynamic-plugins/dist \
    ./dynamic-plugins/dist

# ----------------------------------
# Config
# ----------------------------------
COPY app-config.yaml .
COPY app-config.production.yaml .
COPY app-config.dynamic-plugins.yaml .

RUN chown -R 1001:0 /opt/app-root/src

USER 1001

CMD ["node", "packages/backend", "--config", "app-config.yaml", "--config", "app-config.production.yaml"]