# =============================
# Base Image (RHDH Official)
# =============================
FROM registry.access.redhat.com/rhdh/rhdh-hub-rhel9:1779841586

WORKDIR /opt/app-root/src

ENV NODE_ENV=production
ENV NODE_PATH=/opt/app-root/src/node_modules

# =============================
# 必要ツール（必要なら）
# =============================
USER root
RUN microdnf install -y jq && microdnf clean all || true

USER 1001

# =============================
# カスタム dynamic plugins（必要な場合のみ）
# =============================
COPY dynamic-plugins /dynamic-plugins

# =============================
# カスタム設定（必要なら）
# =============================
COPY app-config.yaml /opt/app-root/src/app-config/
COPY app-config.production.yaml /opt/app-root/src/app-config/

# =============================
# 追加ライブラリがある場合のみ（任意）
# =============================
# COPY custom-node-modules /opt/app-root/src/node_modules

# =============================
# RHDHは build しない（重要）
# =============================
# yarn install ❌ 不要
# yarn build ❌ 不要
# node packages/backend ❌ 禁止

# =============================
# 起動はベースイメージに任せる
# =============================