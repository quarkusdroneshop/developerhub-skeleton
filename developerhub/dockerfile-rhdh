# ==================================================
# 1. Build stage
# ==================================================
FROM node:20.18.3 AS builder

WORKDIR /app

# ----------------------------------
# Yarn / native build 安定化
# ----------------------------------
ENV npm_config_build_from_source=false \
    npm_config_ignore_optional=true \
    YARN_ENABLE_SCRIPTS=1

# ----------------------------------
# System deps
# ----------------------------------
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    gcc \
    pkg-config \
    git \
    build-essential \
 && rm -rf /var/lib/apt/lists/*

# ----------------------------------
# Corepack + Yarn
# ----------------------------------
RUN corepack enable \
 && corepack prepare yarn@4.16.0 --activate

# ----------------------------------
# 依存定義のみ先にコピー
# ----------------------------------
COPY package.json yarn.lock .yarnrc.yml ./

# Yarn v4 metadata
COPY .yarn .yarn

# workspace package 定義
COPY packages packages
COPY plugins plugins
COPY dynamic-plugins dynamic-plugins

# ----------------------------------
# Yarn config
# ----------------------------------
RUN yarn config set nodeLinker node-modules

RUN echo "===== Yarn enableScripts =====" \
 && yarn config get enableScripts

RUN echo "===== .yarnrc.yml =====" \
 && cat .yarnrc.yml || true

# ----------------------------------
# Install
# ----------------------------------
RUN yarn install --immutable --inline-builds

# ----------------------------------
# ソース全体をコピー
# ----------------------------------
COPY . .

# ----------------------------------
# Build Backstage
# ----------------------------------
RUN yarn build

# bundle.tar.gz / skeleton.tar.gz 作成
RUN yarn workspace backend build-image

# ==================================================
# 2. Runtime stage
# ==================================================
FROM registry.redhat.io/rhdh/rhdh-hub-rhel9:1.10.0

WORKDIR /opt/app-root/src

ENV NODE_ENV=production \
    NODE_PATH=/opt/app-root/src/node_modules

# ----------------------------------
# Runtime tools
# ----------------------------------
USER 0
RUN microdnf install -y jq && microdnf clean all || true
USER 1001

# ----------------------------------
# Backend
# ----------------------------------
COPY --from=builder /app/packages/backend/dist \
    /opt/app-root/src/packages/backend/dist

COPY --from=builder /app/packages/backend/package.json \
    /opt/app-root/src/packages/backend/package.json

# ----------------------------------
# Frontend
# ----------------------------------
COPY --from=builder /app/packages/app/dist \
    /opt/app-root/src/packages/app/dist

# ----------------------------------
# Production dependencies
# ----------------------------------
COPY --from=builder /app/node_modules \
    /opt/app-root/src/node_modules

# ----------------------------------
# Backstage bundles
# ----------------------------------
COPY --from=builder /app/dist/skeleton.tar.gz \
    /opt/app-root/src/skeleton.tar.gz

COPY --from=builder /app/dist/bundle.tar.gz \
    /opt/app-root/src/bundle.tar.gz

# ----------------------------------
# Dynamic plugins
# ----------------------------------
COPY --from=builder /app/dynamic-plugins/dist \
    /opt/app-root/src/dynamic-plugins/dist

# ----------------------------------
# Config
# ----------------------------------
COPY app-config.yaml \
    /opt/app-root/src/app-config/

COPY app-config.production.yaml \
    /opt/app-root/src/app-config/

COPY app-config.dynamic-plugins.yaml \
    /opt/app-root/src/app-config/

CMD ["node", "packages/backend"]