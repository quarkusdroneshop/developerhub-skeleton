# =============================
# Base Image
# =============================
FROM node:22-bullseye-slim
WORKDIR /opt/app-root/src

ENV NODE_ENV=production
ENV NODE_PATH=/opt/app-root/src/node_modules

# 必要ツール
RUN apt-get update && apt-get install -y jq && rm -rf /var/lib/apt/lists/*

# =============================
# 依存コピー（ここで package.json がある状態にする）
# =============================
COPY package.json yarn.lock .yarnrc.yml ./
COPY .yarn .yarn

# =============================
# Yarn 設定（プロジェクト内で実行可能）
# =============================
RUN corepack enable && corepack prepare yarn@4.13.0 --activate
RUN yarn config set nodeLinker node-modules
RUN yarn config set enableImmutableInstalls false

# =============================
# packages, plugins, dynamic-plugins のコピー
# =============================
COPY packages packages
COPY plugins plugins
COPY dynamic-plugins dynamic-plugins

# =============================
# ホスト側でビルド済み dist-dynamic を名前付きで node_modules にコピー
# =============================
RUN mkdir -p node_modules
RUN for plugin in dynamic-plugins/*/dist-dynamic; do \
      if [ -d "$plugin" ]; then \
          PLUGIN_NAME=$(basename $(dirname "$plugin")); \
          echo "Copying dynamic plugin: $PLUGIN_NAME"; \
          mkdir -p node_modules/$PLUGIN_NAME; \
          cp -r "$plugin"/* node_modules/$PLUGIN_NAME/; \
      fi \
    done

# =============================
# 全体ビルド（必要であれば）
# =============================
COPY . .

# node_modules 再インストール（古いものを削除）
RUN rm -rf node_modules
RUN yarn install

# =============================
# 起動
# =============================
CMD ["node", "packages/backend/dist/index.cjs.js"]