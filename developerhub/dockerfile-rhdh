FROM registry.redhat.io/rhdh/rhdh-hub-rhel9:1.10.1

ENV NODE_ENV=production \
    NODE_OPTIONS="--max_old_space_size=2048" \
    NODE_PATH="/opt/backstage/node_modules:/opt/app-root/src/node_modules"

USER 0

RUN microdnf install -y \
    jq \
    tar \
    gzip \
 && microdnf clean all

RUN mkdir -p /opt/backstage

COPY skeleton.tar.gz /opt/backstage/
COPY bundle.tar.gz   /opt/backstage/

RUN cd /opt/backstage \
 && tar xzf skeleton.tar.gz \
 && tar xzf bundle.tar.gz \
 && rm -f skeleton.tar.gz bundle.tar.gz \
 && echo "=== dist ===" && ls packages/backend/dist/ \
 && echo "=== plugins ===" && ls plugins/

RUN echo "=== node_modules コピー ===" \
 && cp -a /opt/app-root/src/node_modules /opt/backstage/node_modules \
 && echo "=== コピー完了: $(ls /opt/backstage/node_modules | wc -l) パッケージ ==="

# RHDH 1.10のScalprumコールバック登録(__load_plugin_entry__)に対応した
# 標準フロントエンドバンドルで置き換え（スケルトンの旧版は未対応）
RUN rm -rf /opt/backstage/packages/app/dist \
 && cp -a /opt/app-root/src/packages/app/dist /opt/backstage/packages/app/dist

RUN mkdir -p /opt/backstage/node_modules/@internal \
 && ln -sfn /opt/backstage/plugins/dynamic-plugins-info-backend \
    /opt/backstage/node_modules/@internal/plugin-dynamic-plugins-info-backend \
 && ln -sfn /opt/backstage/plugins/licensed-users-info-backend \
    /opt/backstage/node_modules/@internal/plugin-licensed-users-info-backend \
 && ln -sfn /opt/backstage/plugins/scalprum-backend \
    /opt/backstage/node_modules/@internal/plugin-scalprum-backend

RUN ls /opt/backstage/node_modules/@backstage/backend-defaults/package.json \
 && echo "=== @backstage/backend-defaults OK ===" \
 && ls /opt/backstage/node_modules/@internal/

WORKDIR /opt/app-root/src
COPY app-config.yaml .
COPY app-config.production.yaml .
COPY app-config.dynamic-plugins.yaml .

RUN chown -R 1001:0 /opt/app-root/src /opt/backstage \
 && chmod -R a+rX /opt/backstage

USER 1001

ENTRYPOINT ["/bin/sh", "-c", "echo '=== UID:' $(id) && echo '=== /opt/backstage/:' $(ls /opt/backstage/) && echo '=== dist/:' $(ls /opt/backstage/packages/backend/dist/) && exec node /opt/backstage/packages/backend/dist/index.cjs.js \"$@\"", "--"]
